# Required: your wallet private key (with 0x prefix)
# NEVER commit this file with a real key!
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: for contract verification on BaseScan (and every other EVM chain).
# Etherscan V2 API uses a single key across 60+ chains.
# Get a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Optional: override the default RPC endpoint
# RPC_URL=https://sepolia.base.org

# Optional: skip deployment of specific contracts, reuse existing addresses
# AGENT_REGISTRY_ADDRESS=0x...
# AGENT_MEMORY_ADDRESS=0x...
# AGENT_REPUTATION_ADDRESS=0x...
# ONLY=AgentMemory,AgentReputation
