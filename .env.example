# ── Deployment / registration signer ──────────────────────────────────
# The wallet that deploys contracts and registers agents (as creator).
# NEVER commit this file with a real key!
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Alias for the same key when the context is "registering an agent":
# CREATOR_PRIVATE_KEY=0x...

# ── BaseScan / Etherscan verification ────────────────────────────────
# Etherscan V2 API uses a single key across 60+ chains.
# Get a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ── IPFS pinning for agent metadata ──────────────────────────────────
# Pinata JWT — get a free one at https://app.pinata.cloud/keys
PINATA_JWT=
# Optional: Storacha (Filecoin-backed IPFS) for dual-pin redundancy
# Get a token at https://console.storacha.network
# W3S_TOKEN=
# Comma-separated for dual pinning: PIN_PROVIDERS=pinata,storacha
# Single provider (default): PIN_PROVIDER=pinata
# Fallback (no external service): PIN_PROVIDER=none

# ── Agent keystore encryption ────────────────────────────────────────
# Agent wallets are saved to agents/ as encrypted Web3 JSON keystores.
# If set, this password is used for encrypt/decrypt without prompting.
# Leave empty to prompt interactively (safer — key isn't in any file).
# KEYSTORE_PASSWORD=

# ── Optional overrides ───────────────────────────────────────────────
# RPC_URL=https://sepolia.base.org
# CHAIN_ID=84532
# DELEGATION_DAYS=365

# Skip deployment of specific contracts, reuse existing addresses:
# AGENT_REGISTRY_ADDRESS=0x...
# AGENT_MEMORY_ADDRESS=0x...
# AGENT_REPUTATION_ADDRESS=0x...
# ONLY=AgentMemory,AgentReputation
