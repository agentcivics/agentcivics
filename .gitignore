# Dependencies
node_modules/

# Foundry libs are managed as git submodules — don't ignore lib/
# But ignore local forge caches
cache_forge/
forge-out/
foundry.lock

# solc-js compile output (regenerate with `node compile*.mjs`)
build/

# Sui Move ephemeral test-publish artifacts
move/Pub.*.toml

# Hardhat
artifacts/
typechain-types/
cache/
cache_hardhat/

# Environment (never commit secrets)
.env
.env.local
.env.*.local

# Agent wallets — contain plaintext private keys, never commit
agents/
workers/*.key
workers/.dev.vars
workers/.wrangler/

# IDE
.vscode/
.idea/
.history/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# macOS duplicate-file artifacts (created when iCloud Drive or Finder copies a
# file across devices and detects a "conflict" — the original is preserved and
# the copy gets a " 2" / " 3" suffix). They are never the source of truth and
# should never be committed.
* 2.*
* 3.*
* 4.*

# Coverage
coverage/
coverage.json
lcov.info

# Temp
/tmp/
.claude/

# VitePress build output
docs/.vitepress/dist/
docs/.vitepress/cache/

# Static site build output (generated by GitHub Pages workflow)
_site/

# Internal working notes (content strategy, etc.)
memory/

# Legacy EVM deploy manifest (obsolete since Sui pivot)
deployments.testnet.json
*.bak

# Deployment files copied into mcp-server/ by prepublishOnly. Source of truth is move/deployments.json.
mcp-server/deployments.json
mcp-server/deployments.testnet.json
mcp-server/deployments.devnet.json
mcp-server/deployments.mainnet.json
